{
  "name": "@aircury/ai-framework",
  "description": "Aircury AI Framework installer — sets up hexagonal architecture, DDD, TDD, and AI agent configs in any project",
  "bin": {
    "ai-framework": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": "https://github.com/aircury/ai-framework",
  "scripts": {
    "start": "bun run src/cli.ts",
    "legacy-specs": "bun run src/legacy-spec-orchestrator.ts",
    "build": "bun build src/cli.ts --outfile dist/cli.js --target node --sourcemap=none",
    "test": "bun test",
    "lint": "biome check --fix",
    "format": "biome format --write"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "handlebars": "^4.7.8"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@types/bun": "^1.3.11",
    "typescript": "^6.0.2"
  }
}
